# ── LLM: Mistral ───────────────────────────────────────────────────────────────
# Ottieni la chiave su https://console.mistral.ai → API Keys
MISTRAL_API_KEY=sdfdfd

# Modello da usare: mistral-large-latest, mistral-small-latest, open-mistral-7b, ...
MISTRAL_MODEL=mistral-large-latest

# ── Trascrizione audio: Groq ───────────────────────────────────────────────────
# Ottieni la chiave su https://console.groq.com → API Keys
GROQ_API_KEY=your_groq_api_key_here

# ── Telegram Bot (opzionale) ────────────────────────────────────────────────────
# Crea un bot con @BotFather su Telegram → copia il token qui
# Lascia vuoto per disabilitare il bot Telegram
TELEGRAM_BOT_TOKEN=
